{
  "name": "agentic-commerce-for-salesforce-commerce",
  "version": "0.2.2",
  "description": "Agentic commerce for Salesforce Commerce Cloud B2C. Multi-protocol (ACP, UCP, AP2) discovery + cart-handoff service. Ships /llms.txt, /.well-known/ucp, robots.txt allowlist for real AI crawlers, schema.org JSON-LD on PDPs, signed-JWT cart-deeplink redemption, and full ACP/UCP/AP2 REST endpoint stack. Implements @xpaysh/adapter-contract against the OCAPI Shop API. Rail-agnostic.",
  "private": true,
  "license": "Apache-2.0",
  "author": "xpay✦ <hello@xpay.sh>",
  "homepage": "https://github.com/xpaysh/agentic-commerce-for-salesforce-commerce#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xpaysh/agentic-commerce-for-salesforce-commerce.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentic-commerce-for-salesforce-commerce": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --watch --import tsx/esm src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx tests/conformance.test.ts"
  },
  "dependencies": {
    "@xpaysh/adapter-contract": "^0.1.0",
    "@xpaysh/cart-deeplinks": "^0.1.0",
    "@xpaysh/discovery": "^0.1.0",
    "@xpaysh/ucp-schemas": "^0.2.0",
    "@xpaysh/acp-schemas": "^0.1.0",
    "@xpaysh/http-message-signatures": "^0.1.0",
    "@xpaysh/acp-session-store": "^0.1.0",
    "@aws-sdk/client-dynamodb": "^3.600.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@xpaysh/conformance-fixtures": "^0.2.0",
    "ajv": "^8.20.0"
  },
  "engines": {
    "node": ">=18"
  }
}
