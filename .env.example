# Per-merchant identity
XPAY_MERCHANT_SLUG=acme-outdoors
SITE_URL=https://store.acme.example/
SITE_NAME=Acme Outdoors
SITE_DESCRIPTION=Climbing gear and trail food

# Shared HS256 secret for cart-deeplink JWTs
# Get from your xpay merchant account: app.xpay.sh/onboard/salesforce-commerce
XPAY_API_KEY=xpay_live_REPLACE_ME

# Salesforce Commerce Cloud B2C — OCAPI Shop API
# Instance host (production / sandbox / staging)
SFCC_INSTANCE=zzzz-aaaa.dx.commercecloud.salesforce.com
# B2C site / channel id
SFCC_SITE_ID=RefArch
# OCAPI version (e.g. 'v23_2')
SFCC_OCAPI_VERSION=v23_2
# OAuth client_id + client_secret for OCAPI client_credentials grant
# Configure under: Business Manager → Administration → Site Development →
# Open Commerce API Settings → Shop (set the client_id JSON allowlist for
# the endpoints below); Account Manager → API Client → Create.
SFCC_CLIENT_ID=REPLACE_WITH_CLIENT_ID
SFCC_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
# Auth token endpoint — default to the modern Account Manager host
SFCC_AUTH_URL=https://account.demandware.com/dw/oauth2/access_token

# Optional
HOST=0.0.0.0
PORT=8787
CHECKOUT_PATH=/checkout
EMIT_OAUTH_PROTECTED_RESOURCE=0
EMIT_AGENT_CARD=0
